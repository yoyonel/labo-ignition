brew "git-delta"

# Visualisation d'espace disque en arbre intuitif
brew "dust"

# Moniteur système full TUI (CPU, RAM, GPU, réseau)
brew "btop"

# Liste de processus moderne et lisible
brew "procs"

# Benchmarking CLI avec statistiques et warmup
brew "hyperfine"

# Rendu Markdown dans le terminal
